{
  "name": "lightslide",
  "version": "0.13.0",
  "description": "Lightweight, accessible-by-default React carousel & slider: WAI-ARIA semantics out of the box, built-in navigation, pagination, autoplay, infinite loop, continuous flow (ticker) mode, and typed analytics. ~5 kB core, zero runtime dependencies beyond React.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./a11y": {
      "types": "./dist/a11y.d.ts",
      "import": "./dist/a11y.esm.js",
      "require": "./dist/a11y.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.esm.js",
      "require": "./dist/navigation.js"
    },
    "./pagination": {
      "types": "./dist/pagination.d.ts",
      "import": "./dist/pagination.esm.js",
      "require": "./dist/pagination.js"
    },
    "./flow": {
      "types": "./dist/flow.d.ts",
      "import": "./dist/flow.esm.js",
      "require": "./dist/flow.js"
    },
    "./wheel": {
      "types": "./dist/wheel.d.ts",
      "import": "./dist/wheel.esm.js",
      "require": "./dist/wheel.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\"",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "size": "npm run build && size-limit",
    "playground": "npm install --prefix playground && npm run dev --prefix playground",
    "prepublishOnly": "npm run lint && npm run stylelint && npm test && npm run build"
  },
  "size-limit": [
    {
      "path": "dist/index.esm.js",
      "limit": "5.4 kB"
    },
    {
      "name": "lightslide/a11y (with shared chunks)",
      "path": "dist/a11y.esm.js",
      "limit": "2 kB"
    },
    {
      "name": "lightslide/navigation (with shared chunks)",
      "path": "dist/navigation.esm.js",
      "limit": "1.5 kB"
    },
    {
      "name": "lightslide/pagination (with shared chunks)",
      "path": "dist/pagination.esm.js",
      "limit": "1.5 kB"
    },
    {
      "name": "lightslide/flow (with shared chunks)",
      "path": "dist/flow.esm.js",
      "limit": "1.5 kB"
    },
    {
      "name": "lightslide/wheel (with shared chunks)",
      "path": "dist/wheel.esm.js",
      "limit": "1 kB"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DmitriyBol/lightslide.git"
  },
  "homepage": "https://github.com/DmitriyBol/lightslide#readme",
  "bugs": {
    "url": "https://github.com/DmitriyBol/lightslide/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.49.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@size-limit/preset-small-lib": "^11.1.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.8.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.77.8",
    "size-limit": "^11.1.4",
    "stylelint": "^16.7.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "ts-jest": "^29.1.4",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "react",
    "carousel",
    "slider",
    "swiper",
    "ticker",
    "marquee",
    "analytics",
    "loop",
    "a11y",
    "accessible",
    "accessibility",
    "wai-aria",
    "lightweight",
    "swipe",
    "responsive"
  ],
  "license": "MIT"
}
