{
  "name": "lightslide",
  "version": "1.0.0",
  "description": "Lightweight, accessible-by-default React carousel & slider: WAI-ARIA semantics out of the box, infinite loop, center align, lazy mounting, and zero-CLS SSR in a ~5.5 kB core — navigation, pagination, autoplay, flow (ticker), wheel, free scrolling, breakpoints, and typed analytics as tree-shakeable modules. Zero runtime dependencies beyond React.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./a11y": {
      "types": "./dist/a11y.d.ts",
      "import": "./dist/a11y.mjs",
      "require": "./dist/a11y.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.mjs",
      "require": "./dist/navigation.js"
    },
    "./pagination": {
      "types": "./dist/pagination.d.ts",
      "import": "./dist/pagination.mjs",
      "require": "./dist/pagination.js"
    },
    "./flow": {
      "types": "./dist/flow.d.ts",
      "import": "./dist/flow.mjs",
      "require": "./dist/flow.js"
    },
    "./wheel": {
      "types": "./dist/wheel.d.ts",
      "import": "./dist/wheel.mjs",
      "require": "./dist/wheel.js"
    },
    "./free": {
      "types": "./dist/free.d.ts",
      "import": "./dist/free.mjs",
      "require": "./dist/free.js"
    },
    "./autoplay": {
      "types": "./dist/autoplay.d.ts",
      "import": "./dist/autoplay.mjs",
      "require": "./dist/autoplay.js"
    },
    "./analytics": {
      "types": "./dist/analytics.d.ts",
      "import": "./dist/analytics.mjs",
      "require": "./dist/analytics.js"
    },
    "./breakpoints": {
      "types": "./dist/breakpoints.d.ts",
      "import": "./dist/breakpoints.mjs",
      "require": "./dist/breakpoints.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "a11y": ["dist/a11y.d.ts"],
      "navigation": ["dist/navigation.d.ts"],
      "pagination": ["dist/pagination.d.ts"],
      "flow": ["dist/flow.d.ts"],
      "wheel": ["dist/wheel.d.ts"],
      "free": ["dist/free.d.ts"],
      "autoplay": ["dist/autoplay.d.ts"],
      "analytics": ["dist/analytics.d.ts"],
      "breakpoints": ["dist/breakpoints.d.ts"]
    }
  },
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\"",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "size": "npm run build && size-limit",
    "playground": "npm install --prefix playground && npm run dev --prefix playground",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run stylelint && npm test && npm run size"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "5.5 kB"
    },
    {
      "name": "lightslide/a11y (with shared chunks)",
      "path": "dist/a11y.mjs",
      "limit": "2 kB"
    },
    {
      "name": "lightslide/navigation (with shared chunks)",
      "path": "dist/navigation.mjs",
      "limit": "1.5 kB"
    },
    {
      "name": "lightslide/pagination (with shared chunks)",
      "path": "dist/pagination.mjs",
      "limit": "1.5 kB"
    },
    {
      "name": "lightslide/flow (with shared chunks)",
      "path": "dist/flow.mjs",
      "limit": "1.8 kB"
    },
    {
      "name": "lightslide/wheel (with shared chunks)",
      "path": "dist/wheel.mjs",
      "limit": "1 kB"
    },
    {
      "name": "lightslide/free (with shared chunks)",
      "path": "dist/free.mjs",
      "limit": "1.8 kB"
    },
    {
      "name": "lightslide/autoplay (with shared chunks)",
      "path": "dist/autoplay.mjs",
      "limit": "1 kB"
    },
    {
      "name": "lightslide/analytics (with shared chunks)",
      "path": "dist/analytics.mjs",
      "limit": "1.85 kB"
    },
    {
      "name": "lightslide/breakpoints (with shared chunks)",
      "path": "dist/breakpoints.mjs",
      "limit": "0.6 kB"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DmitriyBol/lightslide.git"
  },
  "homepage": "https://lightslide.vercel.app",
  "bugs": {
    "url": "https://github.com/DmitriyBol/lightslide/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.49.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@size-limit/preset-small-lib": "^11.1.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "globals": "^15.8.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.77.8",
    "size-limit": "^11.1.4",
    "stylelint": "^16.7.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "ts-jest": "^29.1.4",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3"
  },
  "keywords": [
    "react",
    "carousel",
    "slider",
    "swiper",
    "ticker",
    "marquee",
    "analytics",
    "loop",
    "a11y",
    "accessible",
    "accessibility",
    "wai-aria",
    "lightweight",
    "swipe",
    "responsive"
  ],
  "author": "Dmitriy Bol",
  "license": "MIT"
}
