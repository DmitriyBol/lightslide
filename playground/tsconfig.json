{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "lightslide": ["../src/index.ts"],
      "lightslide/a11y": ["../src/modules/a11y/index.ts"],
      "lightslide/navigation": ["../src/modules/Navigation/index.ts"],
      "lightslide/pagination": ["../src/modules/Pagination/index.ts"],
      "lightslide/flow": ["../src/modules/flow/index.ts"],
      "lightslide/wheel": ["../src/modules/wheel/index.ts"],
      "lightslide/free": ["../src/modules/free/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
